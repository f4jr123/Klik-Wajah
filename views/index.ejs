  <script>
    document.addEventListener("DOMContentLoaded", function () {
      // 1. Ambil elemen <p> berdasarkan ID yang tadi kita buat
      const elTanggal = document.getElementById('tanggal-absen');

      // 2. Buat objek tanggal hari ini
      const hariIni = new Date();

      // 3. Atur format tanggal ke bahasa Indonesia (Contoh: "Jumat, 14 November 2025")
      const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
      const tanggalFormat = hariIni.toLocaleDateString('id-ID', options);

      // 4. Masukkan tanggal yang sudah diformat ke dalam elemen <p>
      elTanggal.innerText += tanggalFormat; // 'innerText +=' artinya menambahkan teks
    });
  </script>
