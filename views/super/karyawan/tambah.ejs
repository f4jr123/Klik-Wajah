<%- include('../../partials/_head') %>

    <body class="">
        <%- include('../../partials/_navbar') %>
            <div class="header bg-gradient-primary pb-6 pt-5 pt-md-8"></div>
            <div class="container-fluid mt--7">
                <div class="row"></div>
                <div class="row mt-2">
                    <div class="col"></div>
                </div>
                <div class="card bg-secondary shadow px-5">
                    <div style="margin: 5vh 0 3vh 0 ;">

                        <h2>
                            <% if (typeof dataKaryawan !=='undefined' ) { %>
                                Form Registrasi Ulang Wajah
                                <% } else { %>
                                    Form Tambah Karyawan
                                    <% } %>
                        </h2>
                    </div>

                    <form id="capture-form" role="form" method="post" action="/karyawan/tambah">

                        <% if (typeof dataKaryawan !=='undefined' ) { %>
                            <input type="hidden" name="id" value="<%= dataKaryawan.id %>">
                            <% } %>

                                <div class="form-group">
                                    <label for="example-text-input" class="form-control-label">ID Karyawan</label>
                                    <input class="form-control" type="text" id="example-text-input" name="id_karyawan"
                                        value="<%= (typeof dataKaryawan !== 'undefined') ? dataKaryawan.id_karyawan : '' %>"
                                        <%=(typeof dataKaryawan !=='undefined' ) ? 'readonly' : '' %>
                                    required>
                                </div>

                                <div class="form-group">
                                    <label for="example-text-nama" class="form-control-label">Nama Karyawan</label>
                                    <input class="form-control" type="text" id="example-text-nama" name="nama_karyawan"
                                        value="<%= (typeof dataKaryawan !== 'undefined') ? dataKaryawan.nama_karyawan : '' %>"
                                        <%=(typeof dataKaryawan !=='undefined' ) ? 'readonly' : '' %>
                                    required>
                                </div>

                                <div class="form-group">
                                    <label for="example-text-divisi" class="form-control-label">Divisi</label>
                                    <select class="form-control" id="example-text-divisi"
                                        name="<%= (typeof dataKaryawan !== 'undefined') ? 'id_divisi_display' : 'id_divisi' %>"
                                        <%=(typeof dataKaryawan !=='undefined' ) ? 'disabled' : '' %>
                                        required>

                                        <option value="" disabled <%=(typeof dataKaryawan==='undefined' ) ? 'selected'
                                            : '' %>>Select Option</option>

                                        <% if(rows && rows.length> 0) { %>
                                            <% for(let i=0; i < rows.length; i++) { %>
                                                <option value="<%= rows[i].id_divisi %>" <%=(typeof dataKaryawan
                                                    !=='undefined' && rows[i].id_divisi==dataKaryawan.id_divisi)
                                                    ? 'selected' : '' %>>
                                                    <%= rows[i].nama_divisi %>
                                                </option>
                                                <% } %>
                                                    <% } %>
                                    </select>

                                    <% if (typeof dataKaryawan !=='undefined' ) { %>
                                        <input type="hidden" name="id_divisi" value="<%= dataKaryawan.id_divisi %>">
                                        <% } %>
                                </div>

                                <div class="form-group">
                                    <label class="form-control-label">Wajah Karyawan</label>
                                    <div style="position: relative; width: 600px; height: 450px;">
                                        <video id="kamera-feed" width="600" height="450" autoplay muted
                                            style="border: 1px solid #ddd; position: absolute; top: 0; left: 0;"></video>
                                    </div>
                                </div>

                                <input type="hidden" id="face-descriptor" name="faceDescriptor">

                                <div class="py-4 text-right">
                                    <button type="submit" class="btn btn-primary">
                                        <% if (typeof dataKaryawan !=='undefined' ) { %>
                                            Simpan Wajah Baru
                                            <% } else { %>
                                                Simpan Data Karyawan
                                                <% } %>
                                    </button>
                                </div>

                    </form>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
            <script defer src="/javascripts/script.js"></script>

            <%- include('../../partials/_foot') %>
    </body>