<%- include('../../partials/_head') %>

    <body class="">
        <%- include('../../partials/_navbar') %>
            <div class="header bg-gradient-primary pb-6 pt-5 pt-md-8"></div>

            <div class="container-fluid mt--7">
                <div class="row"></div>
                <div class="row mt-2">
                    <div class="col"></div>
                </div>

                <div class="card bg-secondary shadow px-5">
                    <div style="margin: 5vh 0 3vh 0 ;">
                        <h2>Form Pengajuan Izin / Cuti</h2>
                    </div>

                    <%- include('../../partials/_messages') %>

                        <form role="form" method="post" action="/pengajuan/store" enctype="multipart/form-data">

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-control-label">Tanggal Mulai</label>
                                        <input class="form-control" type="date" name="tgl_mulai" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-control-label">Tanggal Selesai</label>
                                        <input class="form-control" type="date" name="tgl_selesai" required>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group">
                                <label class="form-control-label">Jenis Pengajuan</label>
                                <select class="form-control" name="tipe_izin" required>
                                    <option value="">-- Pilih Jenis --</option>
                                    <option value="Izin">Izin (Kepentingan Pribadi)</option>
                                    <option value="Sakit">Sakit</option>
                                    <option value="Cuti">Cuti Tahunan</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-control-label">Alasan</label>
                                <textarea class="form-control" name="alasan" rows="3"
                                    placeholder="Jelaskan alasan pengajuan Anda..." required></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-control-label">Lampiran (Surat Dokter / Bukti)</label>
                                <input type="file" class="form-control" name="lampiran">
                                <small class="text-muted">Format: PDF, JPG, PNG. Maks 2MB.</small>
                            </div>

                            <div class="py-2 text-right">
                                <a href="/pengajuan" class="btn btn-secondary">Batal</a>
                                <input type="submit" value="Kirim Pengajuan" class="btn btn-info">
                            </div>
                        </form>
                </div>
            </div>
            <%- include('../../partials/_foot') %>
    </body>