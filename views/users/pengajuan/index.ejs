<%- include('../../partials/_head') %>

    <!-- 1. Tambahkan CSS untuk DataTables -->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css">
    <style>
        /* 2. Style untuk tema gelap dan pointer */
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #f8f9fe !important;
            cursor: pointer;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            color: #8898aa !important;
        }

        .dataTables_wrapper .dataTables_length label,
        .dataTables_wrapper .dataTables_filter label {
            color: #f8f9fe;
        }

        .dataTables_wrapper .dataTables_length select {
            background-color: #5e72e4;
            color: #ffffff;
        }

        .dataTables_wrapper .dataTables_filter input {
            background-color: #555;
            color: #ffffff;
        }
    </style>

    <body class="">
        <%- include('../../partials/_navbar') %>
            <div class="header bg-gradient-primary pb-6 pt-5 pt-md-8"></div>

            <div class="container-fluid mt--7">
                <div class="row mt-2">
                    <div class="col">
                        <div class="card bg-default shadow">
                            <!-- Header -->
                            <div
                                class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                                <h3 class="text-white mb-0">Riwayat Pengajuan Saya</h3>
                                <a href="/pengajuan/add" class="btn btn-primary my-2">
                                    <i class="ni ni-fat-add"></i> Ajukan Izin/Cuti
                                </a>
                            </div>

                            <!-- Garis pemisah -->
                            <hr class="my-0" style="border-top: 1px solid rgba(255, 255, 255, 0.1);">

                            <%- include('../../partials/_messages') %>

                                <!-- 3. Wrapper untuk DataTables -->
                                <div class="card-body px-0 py-0">
                                    <div class="table-responsive p-4">
                                        <!-- 4. ID unik untuk tabel -->
                                        <table class="table align-items-center table-dark table-flush"
                                            id="tabel-pengajuan-user">
                                            <thead class="thead-dark">
                                                <tr>
                                                    <th scope="col">No</th>
                                                    <th scope="col">Tgl Mulai</th>
                                                    <th scope="col">Tgl Selesai</th>
                                                    <th scope="col">Tipe</th>
                                                    <th scope="col">Status</th>
                                                    <th scope="col">Lampiran</th>
                                                    <th scope="col" class="text-right">Aksi</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% if (data.length===0) { %>
                                                    <tr>
                                                        <td colspan="7" class="text-center">Anda belum memiliki riwayat
                                                            pengajuan.</td>
                                                    </tr>
                                                    <% } %>

                                                        <% for(var i=0; i < data.length; i++) { %>
                                                            <tr>
                                                                <th scope="row">
                                                                    <%= i+1 %>
                                                                </th>
                                                                <td>
                                                                    <%= data[i].tgl_mulai %>
                                                                </td>
                                                                <td>
                                                                    <%= data[i].tgl_selesai %>
                                                                </td>
                                                                <td>
                                                                    <%= data[i].tipe_izin %>
                                                                </td>

                                                                <td>
                                                                    <% if(data[i].status=='pending' ) { %>
                                                                        <span class="badge badge-dot mr-4"><i
                                                                                class="bg-warning"></i> Pending</span>
                                                                        <% } else if(data[i].status=='acc' ) { %>
                                                                            <span class="badge badge-dot mr-4"><i
                                                                                    class="bg-success"></i>
                                                                                Disetujui</span>
                                                                            <% } else { %>
                                                                                <span class="badge badge-dot mr-4"><i
                                                                                        class="bg-danger"></i>
                                                                                    Ditolak</span>
                                                                                <% } %>
                                                                </td>

                                                                <td>
                                                                    <% if(data[i].lampiran) { %>
                                                                        <a href="/uploads/lampiran/<%= data[i].lampiran %>"
                                                                            target="_blank"
                                                                            class="btn btn-sm btn-neutral">
                                                                            <i class="ni ni-cloud-download-95"></i>
                                                                        </a>
                                                                        <% } else { %> - <% } %>
                                                                </td>

                                                                <td class="text-right">
                                                                    <% if (data[i].status=='pending' ) { %>
                                                                        <a href="/pengajuan/delete/<%= data[i].id %>"
                                                                            onclick="return confirm('Batalkan pengajuan ini?')"
                                                                            class="btn btn-sm btn-danger">
                                                                            <i class="ni ni-basket"></i> Batal
                                                                        </a>
                                                                        <% } else { %>
                                                                            -
                                                                            <% } %>
                                                                </td>
                                                            </tr>
                                                            <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../../partials/_foot') %>

                <!-- 5. Skrip DataTables (ditaruh setelah _foot agar jQuery termuat) -->

                <!-- Library DataTables -->
                <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
                <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

                <!-- Inisialisasi DataTables -->
                <script>
                    $(document).ready(function () {
                        $('#tabel-pengajuan-user').DataTable({
                            "language": {
                                "search": "Cari:",
                                "lengthMenu": "Tampilkan _MENU_ data",
                                "info": "Menampilkan _START_ s/d _END_ dari _TOTAL_ data",
                                "infoEmpty": "Menampilkan 0 data",
                                "infoFiltered": "(disaring dari _MAX_ total data)",
                                "zeroRecords": "Tidak ada data yang cocok",
                                "paginate": {
                                    "first": "Awal",
                                    "last": "Akhir",
                                    "next": "<i class='ni ni-bold-right'></i>",
                                    "previous": "<i class='ni ni-bold-left'></i>"
                                }
                            },
                            // Nonaktifkan sorting untuk kolom "Lampiran" (indeks 5) dan "Aksi" (indeks 6)
                            "columnDefs": [
                                { "orderable": false, "targets": [5, 6] }
                            ]
                        });
                    });
                </script>