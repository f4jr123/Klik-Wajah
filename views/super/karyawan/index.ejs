<%- include('../../partials/_head') %>

    <!-- 1. Tambahkan CSS untuk DataTables -->
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css">
    <style>
        /* 2. Tambahkan Style untuk tema gelap dan pointer */
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            color: #f8f9fe !important;
            cursor: pointer;
        }

        .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
            color: #8898aa !important;
        }

        .dataTables_wrapper .dataTables_length label,
        .dataTables_wrapper .dataTables_filter label {
            color: #f8f9fe;
        }

        .dataTables_wrapper .dataTables_length select {
            background-color: #5e72e4;
            color: #ffffff;
        }

        .dataTables_wrapper .dataTables_filter input {
            background-color: #555;
            color: #ffffff;
        }
    </style>

    <body class="">
        <%- include('../../partials/_navbar') %>
            <div class="header bg-gradient-primary pb-6 pt-5 pt-md-8"></div>
            <div class="container-fluid mt--7">
                <div class="row"></div>
                <div class="row mt-2">
                    <div class="col">

                        <div class="row"></div>
                        <div class="row mt-2">
                            <div class="col">
                            </div>
                        </div>
                        <div class="card bg-default shadow">
                            <div
                                class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center">
                                <h3 class="text-white mb-0">Data Karyawan</h3>
                                <a href="/karyawan/add" class="btn btn-primary my-2">
                                    Add
                                </a>
                            </div>
                            <hr class="my-0" style="border-top: 1px solid rgba(255, 255, 255, 0.1); margin: 0%;">
                            <%- include('../../partials/_messages') %>
                                <div class="card-body px-0 py-0">
                                    <div class="table-responsive p-4">
                                        <table class="table align-items-center table-dark table-flush"
                                            id="tabel-karyawan">
                                            <thead class="thead-dark">
                                                <tr>
                                                    <th scope="col">#</th>
                                                    <th scope="col">ID Karyawan</th>
                                                    <th scope="col">Nama Karyawan</th>
                                                    <th scope="col">Divisi</th>
                                                    <th scope="col">Manajemen Wajah</th>
                                                    <th scope="col" style="width: 20%;">Aksi</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <% for(var i=0; i < data.length; i++){ %>
                                                    <tr>
                                                        <th scope="row">
                                                            <%= i+1 %>
                                                        </th>
                                                        <td>
                                                            <%= data[i].id_karyawan %>
                                                        </td>
                                                        <td>
                                                            <%= data[i].nama_karyawan %>
                                                        </td>
                                                        <td>
                                                            000-<%= data[i].id_divisi %>
                                                        </td>

                                                        <td>
                                                            <% if (data[i].wajah && data[i].wajah.length> 2) { %>

                                                                <span class="badge badge-dot mr-4">
                                                                    <i class="bg-success"></i> Terdaftar
                                                                </span>
                                                                <br>
                                                                <a href="/karyawan/re-register/<%= data[i].id %>"
                                                                    class="btn btn-sm btn-primary mt-2">
                                                                    Reg. Ulang
                                                                </a>
                                                                <a href="/karyawan/delete-face/<%= data[i].id %>"
                                                                    class="btn btn-sm btn-danger mt-2"
                                                                    onclick="return confirm('Yakin menghapus data wajah karyawan ini? Data teks tidak akan terhapus.')">
                                                                    Hapus Wajah
                                                                </a>

                                                                <% } else { %>

                                                                    <span class="badge badge-dot mr-4">
                                                                        <i class="bg-warning"></i> Belum Terdaftar
                                                                    </span>
                                                                    <br>
                                                                    <a href="/karyawan/re-register/<%= data[i].id %>"
                                                                        class="btn btn-sm btn-success mt-2">
                                                                        Registrasi Wajah
                                                                    </a>

                                                                    <% } %>
                                                        </td>

                                                        <td>
                                                            <a href="/karyawan/edit/<%= data[i].id %>"
                                                                class="btn btn-info">Edit</a>
                                                            <a href="/karyawan/delete/<%= data[i].id_karyawan %>"
                                                                onclick="return confirm('Yakin mau menghapus karyawan ini?')"
                                                                class="btn btn-warning">Hapus</a>
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                        </div>
                    </div>
                </div>
            </div>
            </div>
            <%- include('../../partials/_foot') %>
                <%- include('../../partials/_scripts_datatable') %>