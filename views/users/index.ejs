<%- include('../partials/_head') %>

    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap4.min.css">
    <style>
        /* Custom Style Dark Theme DataTables */
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate .paginate_button,
        .dataTables_wrapper .dataTables_length label,
        .dataTables_wrapper .dataTables_filter label {
            color: #f8f9fe !important;
        }

        .dataTables_wrapper .dataTables_length select,
        .dataTables_wrapper .dataTables_filter input {
            background-color: #172b4d;
            color: #fff;
            border: 1px solid #525f7f;
        }

        .page-item.active .page-link {
            background-color: #5e72e4;
            border-color: #5e72e4;
        }
    </style>

    <body class="">
        <%- include('../partials/_navbar') %>

            <div class="header bg-gradient-primary pb-8 pt-5 pt-md-8">
                <div class="container-fluid">
                    <div class="header-body">
                        <h6 class="h2 text-white d-inline-block mb-3">Statistik Bulan Ini</h6>
                        <div class="row">
                            <div class="col-xl-3 col-lg-6">
                                <div class="card card-stats mb-4 mb-xl-0">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col">
                                                <h5 class="card-title text-uppercase text-muted mb-0">Hadir</h5>
                                                <span class="h2 font-weight-bold mb-0">
                                                    <%= statistik.hadir %>
                                                </span>
                                            </div>
                                            <div class="col-auto">
                                                <div
                                                    class="icon icon-shape bg-success text-white rounded-circle shadow">
                                                    <i class="fas fa-check"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <p class="mt-3 mb-0 text-muted text-sm">
                                            <span class="text-nowrap">Bulan Ini</span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-3 col-lg-6">
                                <div class="card card-stats mb-4 mb-xl-0">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col">
                                                <h5 class="card-title text-uppercase text-muted mb-0">Telat</h5>
                                                <span class="h2 font-weight-bold mb-0">
                                                    <%= statistik.telat %>
                                                </span>
                                            </div>
                                            <div class="col-auto">
                                                <div
                                                    class="icon icon-shape bg-warning text-white rounded-circle shadow">
                                                    <i class="fas fa-clock"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <p class="mt-3 mb-0 text-muted text-sm">
                                            <span class="text-nowrap">Bulan Ini</span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-3 col-lg-6">
                                <div class="card card-stats mb-4 mb-xl-0">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col">
                                                <h5 class="card-title text-uppercase text-muted mb-0">Izin/Sakit</h5>
                                                <span class="h2 font-weight-bold mb-0">
                                                    <%= statistik.izin %>
                                                </span>
                                            </div>
                                            <div class="col-auto">
                                                <div class="icon icon-shape bg-info text-white rounded-circle shadow">
                                                    <i class="fas fa-notes-medical"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <p class="mt-3 mb-0 text-muted text-sm">
                                            <span class="text-nowrap">Bulan Ini</span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-xl-3 col-lg-6">
                                <div class="card card-stats mb-4 mb-xl-0">
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col">
                                                <h5 class="card-title text-uppercase text-muted mb-0">Alpha</h5>
                                                <span class="h2 font-weight-bold mb-0">
                                                    <%= statistik.alpha %>
                                                </span>
                                            </div>
                                            <div class="col-auto">
                                                <div class="icon icon-shape bg-danger text-white rounded-circle shadow">
                                                    <i class="fas fa-times"></i>
                                                </div>
                                            </div>
                                        </div>
                                        <p class="mt-3 mb-0 text-muted text-sm">
                                            <span class="text-nowrap">Bulan Ini</span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="container-fluid mt--7">

                <div class="row mb-4">
                    <div class="col-xl-12">
                        <div class="card shadow bg-secondary">
                            <div class="card-header bg-transparent border-0">
                                <div class="row align-items-center">
                                    <div class="col">
                                        <h6 class="text-uppercase text-muted ls-1 mb-1">Overview</h6>
                                        <h2 class="mb-0">Absensi Hari Ini</h2>
                                    </div>
                                    <div class="col text-right">
                                        <% if(!hari_ini) { %>
                                            <a href="/absensi" class="btn btn-primary">Lakukan Absen</a>
                                            <% } else if (!hari_ini.checkout) { %>
                                                <a href="/absensi" class="btn btn-warning">Checkout Sekarang</a>
                                                <% } else { %>
                                                    <button class="btn btn-success" disabled>Selesai</button>
                                                    <% } %>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="row text-center">
                                    <div class="col-md-4">
                                        <div class="card bg-default shadow border-0 mb-3">
                                            <div class="card-body py-3">
                                                <h5 class="text-white mb-1">JAM MASUK</h5>
                                                <h2 class="text-success mb-0">
                                                    <%= (hari_ini && hari_ini.checkin) ? hari_ini.checkin : '--:--' %>
                                                </h2>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card bg-default shadow border-0 mb-3">
                                            <div class="card-body py-3">
                                                <h5 class="text-white mb-1">JAM PULANG</h5>
                                                <h2 class="text-danger mb-0">
                                                    <%= (hari_ini && hari_ini.checkout) ? hari_ini.checkout : '--:--' %>
                                                </h2>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card bg-default shadow border-0 mb-3">
                                            <div class="card-body py-3">
                                                <h5 class="text-muted mb-1">STATUS</h5>
                                                <% if(hari_ini && hari_ini.status) { %>
                                                    <h2 class="text-primary mb-0">
                                                        <%= hari_ini.status.toUpperCase() %>
                                                    </h2>
                                                    <% } else { %>
                                                        <h2 class="text-muted mb-0">BELUM ABSEN</h2>
                                                        <% } %>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <%- include('../partials/_foot') %>

                <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
                <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
                <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>
                <script>
                    $(document).ready(function () {
                        $('#tabel-absensi-user').DataTable({
                            "language": {
                                "search": "Cari:",
                                "lengthMenu": "_MENU_",
                                "info": "Show _START_ to _END_",
                                "paginate": { "next": ">", "previous": "<" }
                            },
                            "order": [[0, "desc"]]
                        });
                    });
                </script>
    </body>